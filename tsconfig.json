{
  "exclude": ["skills"],
  "compilerOptions": {
    "lib": ["ES2024", "DOM"],
    "types": ["@hiogawa/vite-plugin-fullstack/types", "vite/client"],
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "jsxImportSource": "srv-jsx",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
  },
}
